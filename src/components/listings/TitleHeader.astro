---
import { Icon } from "astro-icon/components";
import Image from "astro/components/Image.astro";

const { title, link, linkText, description, image, phone, email, address, languages, specialties, hours, representative, founded, credentials, google_rating, google_reviews, highlights } = Astro.props;
---

<div class="mb-10">
  <div class="flex justify-between items-end">
    <div>
      {image && <Image class="h-15 w-15 mb-8" src={image} alt={title} />}
      <h1 class="font-bold text-4xl text-gray-900 dark:text-gray-50">
        {title}
      </h1>
      {representative && (
        <p class="text-lg text-gray-500 dark:text-gray-400 mt-1">
          {representative}{founded ? ` · Est. ${founded}` : ''}
        </p>
      )}
      {!representative && founded && (
        <p class="text-lg text-gray-500 dark:text-gray-400 mt-1">
          Est. {founded}
        </p>
      )}
    </div>
    {
      link && (
        <a
          class="inline-flex items-center gap-1 font-medium text-gray-800 dark:text-gray-100"
          href={link}
        >
          {linkText}
          <Icon name="tabler:arrow-up-right" />
        </a>
      )
    }
  </div>
  <p class="text-gray-400 mt-2.5">{description}</p>

  {google_rating && google_reviews && (
    <div class="mt-4 flex items-center gap-2">
      <div class="flex items-center gap-0.5">
        {[1,2,3,4,5].map((star) => (
          <svg class={`w-5 h-5 ${star <= Math.round(google_rating) ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600'}`} fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">{google_rating}</span>
      <span class="text-sm text-gray-500 dark:text-gray-400">({google_reviews} Google reviews)</span>
    </div>
  )}

  {credentials && credentials.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {credentials.map((cred: string) => (
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 text-xs font-medium border border-emerald-200 dark:border-emerald-800">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          {cred}
        </span>
      ))}
    </div>
  )}

  {highlights && highlights.length > 0 && (
    <div class="mt-4 space-y-2">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Why choose this firm</p>
      <ul class="space-y-1.5">
        {highlights.map((h: string) => (
          <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
            <svg class="w-4 h-4 mt-0.5 text-blue-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            {h}
          </li>
        ))}
      </ul>
    </div>
  )}

  {(phone || email || address || languages || specialties || hours) && (
    <div class="mt-6 rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-3 text-sm">
      {address && (
        <div class="flex items-start gap-2">
          <Icon name="tabler:map-pin" class="w-4 h-4 mt-0.5 text-gray-400 shrink-0" />
          <span class="text-gray-600 dark:text-gray-300">{address}</span>
        </div>
      )}
      {phone && (
        <div class="flex items-center gap-2">
          <Icon name="tabler:phone" class="w-4 h-4 text-gray-400 shrink-0" />
          <a href={`tel:${phone}`} class="text-gray-600 dark:text-gray-300 hover:text-blue-600">{phone}</a>
        </div>
      )}
      {email && (
        <div class="flex items-center gap-2">
          <Icon name="tabler:mail" class="w-4 h-4 text-gray-400 shrink-0" />
          <a href={`mailto:${email}`} class="text-gray-600 dark:text-gray-300 hover:text-blue-600">{email}</a>
        </div>
      )}
      {hours && (
        <div class="flex items-center gap-2">
          <Icon name="tabler:clock" class="w-4 h-4 text-gray-400 shrink-0" />
          <span class="text-gray-600 dark:text-gray-300">{hours}</span>
        </div>
      )}
      {languages && languages.length > 0 && (
        <div class="flex items-start gap-2">
          <Icon name="tabler:language" class="w-4 h-4 mt-0.5 text-gray-400 shrink-0" />
          <div class="flex flex-wrap gap-1.5">
            {languages.map((lang: string) => (
              <span class="px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-xs font-medium">{lang}</span>
            ))}
          </div>
        </div>
      )}
      {specialties && specialties.length > 0 && (
        <div class="flex items-start gap-2">
          <Icon name="tabler:certificate" class="w-4 h-4 mt-0.5 text-gray-400 shrink-0" />
          <div class="flex flex-wrap gap-1.5">
            {specialties.map((spec: string) => (
              <span class="px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs font-medium">{spec}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</div>

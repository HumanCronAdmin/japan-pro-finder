---
import BaseLayout from "./BaseLayout.astro";
import AppProse from "../components/app/Prose.astro";
const { frontmatter, slug } = Astro.props;
import themeConfig from "@util/themeConfig";
import { Icon } from "astro-icon/components";
import AppShell from "@components/app/AppShell.astro";
import config from "@util/themeConfig";
import SidebarShell from "@components/app/SidebarShell.astro";
import TitleHeader from "@components/listings/TitleHeader.astro";

const siteTitle = themeConfig.general.title;
const title = frontmatter?.title || siteTitle;
const link = frontmatter?.link;
const description = frontmatter?.description;
const linkText = link?.replace(/^https?:\/\//, "");
const pageHeader = themeConfig.listings.pageHeader;
const sidebar = config.layout.sidebar;

const tagToType: Record<string, string> = {
  "lawyer": "Attorney",
  "divorce": "Attorney",
  "labor": "Attorney",
  "corporate": "Attorney",
  "immigration": "Attorney",
  "general": "Attorney",
  "doctor": "Physician",
  "tax-accountant": "AccountingService",
  "financial-advisor": "FinancialService",
  "real-estate": "RealEstateAgent",
};
const tags = frontmatter?.tags || [];
const schemaType = tags.map((t: string) => tagToType[t]).find((t: string) => t) || "ProfessionalService";

const jsonLd: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": schemaType,
  "name": title,
  "description": description,
  "url": `https://japanprofinder.com/${slug}/`,
};
if (link) jsonLd.sameAs = link;
if (frontmatter?.phone) jsonLd.telephone = frontmatter.phone;
if (frontmatter?.email) jsonLd.email = frontmatter.email;
if (frontmatter?.address) {
  jsonLd.address = {
    "@type": "PostalAddress",
    "addressLocality": frontmatter.address,
    "addressCountry": "JP"
  };
}
if (frontmatter?.hours) jsonLd.openingHours = frontmatter.hours;
if (frontmatter?.languages) jsonLd.knowsLanguage = frontmatter.languages;
if (frontmatter?.google_rating && frontmatter?.google_reviews) {
  jsonLd.aggregateRating = {
    "@type": "AggregateRating",
    "ratingValue": frontmatter.google_rating,
    "reviewCount": frontmatter.google_reviews,
    "bestRating": 5,
    "worstRating": 1
  };
}
if (frontmatter?.founded) jsonLd.foundingDate = frontmatter.founded;
---

<BaseLayout title={title} description={description} slug={slug}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {
    sidebar ? (
      <SidebarShell showSidebar={false}>
        <div class="max-w-2xl w-full mx-auto py-20">
          {pageHeader == "title" && (
            <TitleHeader
              title={title}
              description={description}
              link={link}
              linkText={linkText}
              image={frontmatter.image}
              phone={frontmatter.phone}
              email={frontmatter.email}
              address={frontmatter.address}
              languages={frontmatter.languages}
              specialties={frontmatter.specialties}
              hours={frontmatter.hours}
              representative={frontmatter.representative}
              founded={frontmatter.founded}
              credentials={frontmatter.credentials}
              google_rating={frontmatter.google_rating}
              google_reviews={frontmatter.google_reviews}
              highlights={frontmatter.highlights}
            />
          )}
          <AppProse>
            <slot />
          </AppProse>
        </div>
      </SidebarShell>
    ) : (
      <AppShell>
        <div class="max-w-2xl w-full mx-auto py-20">
          {pageHeader == "title" && (
            <TitleHeader
              title={title}
              description={description}
              link={link}
              linkText={linkText}
              image={frontmatter.image}
              phone={frontmatter.phone}
              email={frontmatter.email}
              address={frontmatter.address}
              languages={frontmatter.languages}
              specialties={frontmatter.specialties}
              hours={frontmatter.hours}
              representative={frontmatter.representative}
              founded={frontmatter.founded}
              credentials={frontmatter.credentials}
              google_rating={frontmatter.google_rating}
              google_reviews={frontmatter.google_reviews}
              highlights={frontmatter.highlights}
            />
          )}
          <AppProse>
            <slot />
          </AppProse>
        </div>
      </AppShell>
    )
  }
</BaseLayout>
